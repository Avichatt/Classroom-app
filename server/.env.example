# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://classroom:classroom_secret@localhost:5432/classroom_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-secret-change-me-in-production-use-256-bit
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-too
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3 (optional for local dev — uses local filesystem fallback)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=classroom-uploads

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
